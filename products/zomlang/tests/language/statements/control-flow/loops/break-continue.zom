// CHECK-NEXT:       },
// CHECK-NEXT:       "body": {
// CHECK-NEXT:         "node": "BlockStatement",
// CHECK-NEXT:         "children": [
// CHECK-NEXT:           {
// CHECK-NEXT:             "node": "BreakStatement",
// CHECK-NEXT:             "label": {
// CHECK-NEXT:               "node": "Identifier",
// CHECK-NEXT:               "name": "label1"
// CHECK-NEXT:             }
// CHECK-NEXT:           }
// CHECK-NEXT:         ]
// CHECK-NEXT:       }
// CHECK-NEXT:     },
// CHECK-NEXT:     {
// CHECK-NEXT:       "node": "ForStatement",
// CHECK-NEXT:       "initializer": null,
// CHECK-NEXT:       "condition": null,
// CHECK-NEXT:       "update": null,
// CHECK-NEXT:       "body": {
// CHECK-NEXT:         "node": "BlockStatement",
