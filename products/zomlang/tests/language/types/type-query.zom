// RUN: %zomc compile --dump-ast %s | %FileCheck %s

let x: i32 = 10;
let y: typeof x = 20;


// CHECK: {
// CHECK-NEXT:   "node": "SourceFile",
// CHECK-NEXT:   "fileName": "{{.*type-query.zom}}",
// CHECK-NEXT:   "statements": [
// CHECK-NEXT:     {
// CHECK-NEXT:       "node": "VariableStatement",
// CHECK-NEXT:       "declarations": {
// CHECK-NEXT:         "node": "VariableDeclarationList",
// CHECK-NEXT:         "bindings": [
// CHECK-NEXT:           {
// CHECK-NEXT:             "node": "VariableDeclaration",
// CHECK-NEXT:             "name": {
// CHECK-NEXT:               "node": "Identifier",
// CHECK-NEXT:               "name": "x"
// CHECK-NEXT:             },
// CHECK-NEXT:             "type": {
// CHECK-NEXT:               "node": "I32TypeNode",
// CHECK-NEXT:               "name": "i32"
// CHECK-NEXT:             },
// CHECK-NEXT:             "initializer": {
// CHECK-NEXT:               "node": "IntegerLiteral",
// CHECK-NEXT:               "value": "10"
// CHECK-NEXT:             }
// CHECK-NEXT:           }
// CHECK-NEXT:         ]
// CHECK-NEXT:       }
// CHECK-NEXT:     },
// CHECK-NEXT:     {
// CHECK-NEXT:       "node": "VariableStatement",
// CHECK-NEXT:       "declarations": {
// CHECK-NEXT:         "node": "VariableDeclarationList",
// CHECK-NEXT:         "bindings": [
// CHECK-NEXT:           {
// CHECK-NEXT:             "node": "VariableDeclaration",
// CHECK-NEXT:             "name": {
// CHECK-NEXT:               "node": "Identifier",
// CHECK-NEXT:               "name": "y"
// CHECK-NEXT:             },
// CHECK-NEXT:             "type": {
// CHECK-NEXT:               "node": "TypeQueryNode",
// CHECK-NEXT:               "expression": {
// CHECK-NEXT:                 "node": "Identifier",
// CHECK-NEXT:                 "name": "x"
// CHECK-NEXT:               }
// CHECK-NEXT:             },
// CHECK-NEXT:             "initializer": {
// CHECK-NEXT:               "node": "IntegerLiteral",
// CHECK-NEXT:               "value": "20"
// CHECK-NEXT:             }
// CHECK-NEXT:           }
// CHECK-NEXT:         ]
// CHECK-NEXT:       }
// CHECK-NEXT:     }
// CHECK-NEXT:   ]
// CHECK-NEXT: }
