// RUN: /opt/homebrew/bin/timeout 5s %zomc compile --dump-ast %s | %FileCheck %s

interface Runnable {
  fun run() -> void;
}

interface Comparable<T> {
  fun compareTo(other: T) -> i32;
}

interface Named {
  readonly let name: str;
}


