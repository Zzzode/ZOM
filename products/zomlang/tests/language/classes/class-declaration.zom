// RUN: /opt/homebrew/bin/timeout 5s %zomc compile --dump-ast %s | %FileCheck %s

class Animal {
  public let name: str;

  init(n: str) {
    this.name = n;
  }

  public fun makeSound() -> str {
    return "noise";
  }
}

class Dog extends Animal {
  private let breed: str;

  init(n: str, b: str) {
    super.init(n);
    this.breed = b;
  }

  public fun makeSound() -> str {
    return "Woof";
  }
}


