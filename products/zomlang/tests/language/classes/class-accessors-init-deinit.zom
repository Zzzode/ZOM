// RUN: %zomc compile --dump-ast %s | %FileCheck %s

class C {
  public static let x: i32 = 1;
  private const y: str = "s";

  init(n: i32) { return; }
  deinit { ; }

  get value() -> i32 { return x; }
  set value(n: i32) { return; }
}


