// RUN: %zomc compile --dump-ast %s | %FileCheck %s

let strictEqual = lhs === rhs;
let strictNotEqual = lhs !== rhs;
let fallback = value ?: defaultValue;
let compact = value?:defaultValue;
let mixed = primary ?: secondary ?? tertiary || quaternary;


// CHECK: {
// CHECK-NEXT:   "node": "SourceFile",
// CHECK-NEXT:   "fileName": "{{.*strict-and-error-default.zom}}",
