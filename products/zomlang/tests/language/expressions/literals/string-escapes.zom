// RUN: %zomc compile --dump-ast %s | %FileCheck %s

let newline = "\n";
let tab = "\t";
let returnChar = "\r";
let doubleQuote = "\"";
let singleQuote = "\'";
let backslash = "\\";
let hexEscape = "\x41";
let unicodeEscape = "\u0041";


// CHECK: {
// CHECK-NEXT:   "node": "SourceFile",
// CHECK-NEXT:   "fileName": "{{.*string-escapes.zom}}",
// CHECK-NEXT:   "statements": [
