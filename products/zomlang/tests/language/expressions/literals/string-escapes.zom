// CHECK-NEXT:               "node": "Identifier",
// CHECK-NEXT:               "name": "doubleQuote"
// CHECK-NEXT:             },
// CHECK-NEXT:             "type": null,
// CHECK-NEXT:             "initializer": {
// CHECK-NEXT:               "node": "StringLiteral",
// CHECK-NEXT:               "value": "\""
// CHECK-NEXT:             }
// CHECK-NEXT:           }
// CHECK-NEXT:         ]
// CHECK-NEXT:       }
// CHECK-NEXT:     },
// CHECK-NEXT:     {
