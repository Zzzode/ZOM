// CHECK-NEXT:             }
// CHECK-NEXT:           }
// CHECK-NEXT:         ]
// CHECK-NEXT:       }
// CHECK-NEXT:     },
// CHECK-NEXT:     {
// CHECK-NEXT:       "node": "VariableStatement",
// CHECK-NEXT:       "declarations": {
// CHECK-NEXT:         "node": "VariableDeclarationList",
// CHECK-NEXT:         "bindings": [
// CHECK-NEXT:           {
// CHECK-NEXT:             "node": "VariableDeclaration",
// CHECK-NEXT:             "name": {
// CHECK-NEXT:               "node": "Identifier",
// CHECK-NEXT:               "name": "returnChar"
// CHECK-NEXT:             },
// CHECK-NEXT:             "type": null,
// CHECK-NEXT:             "initializer": {
// CHECK-NEXT:               "node": "StringLiteral",
// CHECK-NEXT:               "value": "{{.*r}}"
// CHECK-NEXT:             }
// CHECK-NEXT:           }
// CHECK-NEXT:         ]
// CHECK-NEXT:       }
// CHECK-NEXT:     },
// CHECK-NEXT:     {
// CHECK-NEXT:       "node": "VariableStatement",
