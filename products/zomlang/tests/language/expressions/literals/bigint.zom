// RUN: %zomc compile --dump-ast %s 2>&1 | %FileCheck %s

// Test for BigInt suffix logic
let a = 123n;
let b = 0x123n;
let c = 0b101n;
let d = 0o123n;


// CHECK: {
// CHECK-NEXT:   "node": "SourceFile",
// CHECK-NEXT:   "fileName": "{{.*bigint.zom}}",
// CHECK-NEXT:   "statements": [
// CHECK-NEXT:     {
// CHECK-NEXT:       "node": "VariableStatement",
// CHECK-NEXT:       "declarations": {
// CHECK-NEXT:         "node": "VariableDeclarationList",
// CHECK-NEXT:         "bindings": [
// CHECK-NEXT:           {
// CHECK-NEXT:             "node": "VariableDeclaration",
// CHECK-NEXT:             "name": {
// CHECK-NEXT:               "node": "Identifier",
// CHECK-NEXT:               "name": "a"
// CHECK-NEXT:             },
// CHECK-NEXT:             "type": null,
// CHECK-NEXT:             "initializer": {
// CHECK-NEXT:               "node": "BigIntLiteral",
// CHECK-NEXT:               "text": "123n"
// CHECK-NEXT:             }
// CHECK-NEXT:           }
// CHECK-NEXT:         ]
// CHECK-NEXT:       }
// CHECK-NEXT:     },
// CHECK-NEXT:     {
// CHECK-NEXT:       "node": "VariableStatement",
// CHECK-NEXT:       "declarations": {
// CHECK-NEXT:         "node": "VariableDeclarationList",
// CHECK-NEXT:         "bindings": [
// CHECK-NEXT:           {
// CHECK-NEXT:             "node": "VariableDeclaration",
// CHECK-NEXT:             "name": {
// CHECK-NEXT:               "node": "Identifier",
// CHECK-NEXT:               "name": "b"
// CHECK-NEXT:             },
// CHECK-NEXT:             "type": null,
// CHECK-NEXT:             "initializer": {
// CHECK-NEXT:               "node": "BigIntLiteral",
// CHECK-NEXT:               "text": "0x123n"
// CHECK-NEXT:             }
// CHECK-NEXT:           }
// CHECK-NEXT:         ]
// CHECK-NEXT:       }
// CHECK-NEXT:     },
// CHECK-NEXT:     {
// CHECK-NEXT:       "node": "VariableStatement",
// CHECK-NEXT:       "declarations": {
// CHECK-NEXT:         "node": "VariableDeclarationList",
// CHECK-NEXT:         "bindings": [
// CHECK-NEXT:           {
// CHECK-NEXT:             "node": "VariableDeclaration",
// CHECK-NEXT:             "name": {
// CHECK-NEXT:               "node": "Identifier",
// CHECK-NEXT:               "name": "c"
// CHECK-NEXT:             },
// CHECK-NEXT:             "type": null,
// CHECK-NEXT:             "initializer": {
// CHECK-NEXT:               "node": "BigIntLiteral",
// CHECK-NEXT:               "text": "5n"
// CHECK-NEXT:             }
// CHECK-NEXT:           }
// CHECK-NEXT:         ]
// CHECK-NEXT:       }
// CHECK-NEXT:     },
// CHECK-NEXT:     {
// CHECK-NEXT:       "node": "VariableStatement",
// CHECK-NEXT:       "declarations": {
// CHECK-NEXT:         "node": "VariableDeclarationList",
// CHECK-NEXT:         "bindings": [
// CHECK-NEXT:           {
// CHECK-NEXT:             "node": "VariableDeclaration",
// CHECK-NEXT:             "name": {
// CHECK-NEXT:               "node": "Identifier",
// CHECK-NEXT:               "name": "d"
// CHECK-NEXT:             },
// CHECK-NEXT:             "type": null,
// CHECK-NEXT:             "initializer": {
// CHECK-NEXT:               "node": "BigIntLiteral",
// CHECK-NEXT:               "text": "83n"
// CHECK-NEXT:             }
// CHECK-NEXT:           }
// CHECK-NEXT:         ]
// CHECK-NEXT:       }
// CHECK-NEXT:     }
// CHECK-NEXT:   ]
// CHECK-NEXT: }
