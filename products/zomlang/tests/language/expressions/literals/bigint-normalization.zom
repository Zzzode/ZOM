// CHECK-NEXT:               "text": "2n"
// CHECK-NEXT:             }
// CHECK-NEXT:           }
// CHECK-NEXT:         ]
// CHECK-NEXT:       }
// CHECK-NEXT:     },
// CHECK-NEXT:     {
// CHECK-NEXT:       "node": "VariableStatement",
// CHECK-NEXT:       "declarations": {
// CHECK-NEXT:         "node": "VariableDeclarationList",
// CHECK-NEXT:         "bindings": [
// CHECK-NEXT:           {
