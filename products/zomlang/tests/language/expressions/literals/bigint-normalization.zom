// CHECK-NEXT:               "name": "a"
// CHECK-NEXT:             },
// CHECK-NEXT:             "type": null,
// CHECK-NEXT:             "initializer": {
// CHECK-NEXT:               "node": "BigIntLiteral",
// CHECK-NEXT:               "text": "10n"
// CHECK-NEXT:             }
// CHECK-NEXT:           }
// CHECK-NEXT:         ]
// CHECK-NEXT:       }
// CHECK-NEXT:     },
