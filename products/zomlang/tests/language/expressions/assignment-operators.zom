// RUN: %zomc compile --dump-ast %s | %FileCheck %s

let a = 1;
let b = 2;
let c = 3;
a = b;
a += b;
a -= b;
a *= b;
a /= b;
a %= b;
a **= b;
a <<= b;
a >>= b;
a >>>= b;
a &= b;
a ^= b;
a |= b;
a &&= b;
a ||= b;
a ??= b;


