// RUN: %zomc compile --dump-ast %s | %FileCheck %s

// Test closure with capture clause
let captureClosure = fun () use [x, &y, this] {
  x
}


// CHECK: {
// CHECK-NEXT:   "node": "SourceFile",
// CHECK-NEXT:   "fileName": "{{.*captures.zom}}",
// CHECK-NEXT:   "statements": [
