// CHECK-NEXT:                   "isByReference": "false",
// CHECK-NEXT:                   "isThis": "true"
// CHECK-NEXT:                 }
// CHECK-NEXT:               ],
// CHECK-NEXT:               "body": {
// CHECK-NEXT:                 "node": "BlockStatement",
// CHECK-NEXT:                 "children": [
// CHECK-NEXT:                   {
