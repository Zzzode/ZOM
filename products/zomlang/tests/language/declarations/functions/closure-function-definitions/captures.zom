// CHECK-NEXT:         "bindings": [
// CHECK-NEXT:           {
// CHECK-NEXT:             "node": "VariableDeclaration",
// CHECK-NEXT:             "name": {
// CHECK-NEXT:               "node": "Identifier",
// CHECK-NEXT:               "name": "captureClosure"
// CHECK-NEXT:             },
// CHECK-NEXT:             "type": null,
// CHECK-NEXT:             "initializer": {
// CHECK-NEXT:               "node": "FunctionExpression",
// CHECK-NEXT:               "parameters": [
// CHECK-NEXT: 
// CHECK-NEXT:               ],
// CHECK-NEXT:               "captures": [
// CHECK-NEXT:                 {
// CHECK-NEXT:                   "node": "CaptureElement",
// CHECK-NEXT:                   "isByReference": "false",
// CHECK-NEXT:                   "isThis": "false",
// CHECK-NEXT:                   "identifier": {
// CHECK-NEXT:                     "node": "Identifier",
// CHECK-NEXT:                     "name": "x"
// CHECK-NEXT:                   }
// CHECK-NEXT:                 },
// CHECK-NEXT:                 {
// CHECK-NEXT:                   "node": "CaptureElement",
// CHECK-NEXT:                   "isByReference": "true",
// CHECK-NEXT:                   "isThis": "false",
// CHECK-NEXT:                   "identifier": {
// CHECK-NEXT:                     "node": "Identifier",
// CHECK-NEXT:                     "name": "y"
// CHECK-NEXT:                   }
// CHECK-NEXT:                 },
// CHECK-NEXT:                 {
